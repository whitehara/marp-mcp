{
  "name": "@masaki39/marp-mcp",
  "version": "1.3.2",
  "description": "MCP server for Marp presentation management with custom theme support",
  "main": "./build/index.js",
  "type": "module",
  "bin": {
    "marp-mcp": "./build/index.js"
  },
  "scripts": {
    "test": "jest",
    "build:ui": "cross-env INPUT=mcp-app.html vite build",
    "build": "tsc && pnpm run build:ui && shx chmod 755 build/index.js",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build",
    "readme:generate": "jest --testPathPattern=readme-generator",
    "skills:generate": "jest --testPathPattern=skill-generator",
    "examples:generate": "jest --testPathPattern=example-generator",
    "examples:html": "pnpm run examples:html:styles && pnpm run examples:html:themes",
    "examples:html:styles": "marp --html --input-dir assets/examples/md --output assets/examples/html --no-config-file",
    "examples:html:themes": "marp --html --input-dir assets/examples/md --output assets/examples/html --theme-set assets/themes/academic.css --no-config-file",
    "examples:server": "marp --html --server --input-dir assets/examples/md --theme-set assets/themes/academic.css --no-config-file"
  },
  "files": [
    "build",
    ".claude/skills",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "marp",
    "presentation",
    "slides",
    "markdown",
    "model-context-protocol",
    "claude",
    "academic-theme"
  ],
  "author": "masaki39",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/masaki39/marp-mcp.git"
  },
  "homepage": "https://github.com/masaki39/marp-mcp#readme",
  "bugs": {
    "url": "https://github.com/masaki39/marp-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "get-east-asian-width": "^1.5.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@marp-team/marp-cli": "^4.2.3",
    "@marp-team/marp-core": "^4.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.6.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
